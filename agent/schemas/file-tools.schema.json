{
	"$schema": "https://json-schema.org/draft-07/schema",
	"$id": "file-tools.schema.json",
	"title": "Pi file-tools config",
	"type": "object",
	"additionalProperties": false,
	"properties": {
		"$schema": {
			"type": "string"
		},
		"blocked_path": {
			"type": "array",
			"default": [".git/"],
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"ignored_path": {
			"type": "array",
			"default": [],
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"limits": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"ls_entries": {
					"type": "integer",
					"minimum": 1,
					"maximum": 10000,
					"default": 200
				},
				"read_lines": {
					"type": "integer",
					"minimum": 1,
					"maximum": 100000,
					"default": 2000
				},
				"read_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 10485760,
					"default": 51200
				},
				"find_output_token_budget": {
					"type": "integer",
					"minimum": 32,
					"maximum": 10000,
					"default": 800
				},
				"find_result_limit": {
					"type": "integer",
					"minimum": 1,
					"maximum": 10000,
					"default": 50
				},
				"find_max_entries_scanned": {
					"type": "integer",
					"minimum": 1,
					"maximum": 1000000,
					"default": 100000
				},
				"grep_output_token_budget": {
					"type": "integer",
					"minimum": 100,
					"maximum": 10000,
					"default": 1600
				},
				"grep_result_limit": {
					"type": "integer",
					"minimum": 1,
					"maximum": 50,
					"default": 8
				},
				"grep_max_file_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 104857600,
					"default": 1048576
				},
				"grep_max_files_scanned": {
					"type": "integer",
					"minimum": 1,
					"maximum": 1000000,
					"default": 100000
				},
				"grep_max_semantic_files": {
					"type": "integer",
					"minimum": 1,
					"maximum": 100000,
					"default": 1024
				},
				"grep_max_semantic_parse_bytes": {
					"type": "integer",
					"minimum": 1024,
					"maximum": 104857600,
					"default": 262144
				}
			}
		},
		"ignore": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"piignore": {
					"type": "boolean",
					"default": true
				},
				"gitignore": {
					"type": "boolean",
					"default": true
				},
				"git_tracked_files_bypass": {
					"type": "boolean",
					"default": true
				},
				"builtin_profile": {
					"type": "string",
					"enum": ["none", "minimal", "performance"],
					"default": "minimal"
				}
			}
		}
	}
}
