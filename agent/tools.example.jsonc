{
  "$schema": "./schemas/tools.schema.json",
  "defaults": {
    "websearch": false
  },
  "rules": [
    {
      "match": "openai-codex/*",
      "tools": {
        "websearch": false,
        "webfetch": false
      }
    },
    {
      "match": "google/*",
      "tools": {
        "websearch": false,
        "webfetch": false
      }
    }
  ]
}
