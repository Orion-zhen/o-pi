{
  "providers": {
    "llama-cpp": {
      "name": "Local AI",
      "baseUrl": "http://127.0.0.1:8000/v1",
      "apiKey": "my-lovely-key",
      "api": "openai-responses",
      "compatPreset": "local",
      "thinkingPreset": "openai",
      "headers": {
        // Cloudflare Tunnel 可能拒绝默认 OpenAI SDK User-Agent。
        "User-Agent": "pi-openai-compatible/1.0"
      },
      "models": [
        {
          "id": "gemma4-31b-it",
          "name": "Gemma4 31B it",
          "contextWindow": 131072,
          "maxTokens": 32768,
          "thinkingPreset": "chat-template-enabled",
          "defaultThinkingLevel": "off",
          "input": ["text", "image"],
          "defaults": {
            "temperature": 0.2,
            "topP": 0.95,
            "topK": 40,
            "maxTokens": 8192
          }
        }
      ]
    },

    "chat-template-effort-demo": {
      "name": "Chat Template Demo",
      "baseUrl": "http://127.0.0.1:11451/v1",
      "apiKey": "EMPTY",
      "api": "openai-responses",
      "compatPreset": "openai-compatible",
      "thinkingPreset": "chat-template-effort",
      "models": [
        {
          "id": "reasoning-model",
          "name": "Reasoning Model",
          "reasoning": true,
          "contextWindow": 65536,
          "maxTokens": 16384,
          "defaultThinkingLevel": "xhigh",
          "thinkingLevelMap": {
            "off": "none",
            "minimal": null,
            "xhigh": "max"
          }
        }
      ]
    },

    "chat-template-enabled-demo": {
      "name": "Chat Template Enabled Demo",
      "baseUrl": "http://127.0.0.1:9000/v1",
      "apiKey": "EMPTY",
      "api": "openai-completions",
      "compatPreset": "local",
      "thinkingPreset": "chat-template-enabled",
      "models": [
        {
          "id": "boolean-thinking-model",
          "name": "Boolean Thinking Model",
          "contextWindow": 131072,
          "maxTokens": 32768,
          "defaultThinkingLevel": "high"
        }
      ]
    }
  }
}
