{
  "providers": {
    "llama-cpp": {
      "name": "Local AI",
      "baseUrl": "http://127.0.0.1:8000/v1",
      "apiKey": "my-lovely-key",
      "api": "openai-completions",
      "thinkingPreset": "openai",
      "headers": {
        // Cloudflare Tunnel 可能拒绝默认 OpenAI SDK User-Agent。
        "User-Agent": "pi-openai-compatible/1.0"
      },

      // compat 是 Pi 原生字段。以下先给出常用本地 Chat Completions 配置，
      // 其余字段以注释形式展示；仅取消确实符合上游行为的项目。
      "compat": {
        // 是否接受 store 字段；不支持时 Pi 不发送 store。
        "supportsStore": false,
        // 是否接受 developer role；false 时 Pi 改用 system role。
        "supportsDeveloperRole": false,
        // 是否接受 reasoning_effort。
        "supportsReasoningEffort": false,
        // 是否接受 stream_options.include_usage。
        "supportsUsageInStreaming": true,
        // 输出 token 上限字段：max_tokens 或 max_completion_tokens。
        "maxTokensField": "max_tokens",

        // tool message 是否必须携带 name。
        // "requiresToolResultName": true,
        // tool message 后接 user message 前是否必须插入 assistant message。
        // "requiresAssistantAfterToolResult": true,
        // 是否把 thinking block 转成带 <thinking> 分隔符的文本。
        // "requiresThinkingAsText": true,
        // replay reasoning assistant 消息时是否必须补空 reasoning_content。
        // "requiresReasoningContentOnAssistantMessages": true,

        // thinking 参数格式；通常由 thinkingPreset 设置，无需同时配置。
        // 可选 openai/openrouter/deepseek/together/zai/qwen/chat-template/
        // qwen-chat-template/string-thinking/ant-ling。
        // "thinkingFormat": "chat-template",
        // thinkingFormat=chat-template 时发送的 chat_template_kwargs；
        // $var 会在请求时替换为 Pi 当前的 thinking 开关或 effort。
        // "chatTemplateKwargs": {
        //   "enable_thinking": { "$var": "thinking.enabled" },
        //   "reasoning_effort": { "$var": "thinking.effort", "omitWhenOff": true }
        // },

        // 是否接受 tool definition 中的 strict 字段。
        // "supportsStrictMode": false,
        // Anthropic 风格 prompt cache_control 标记。
        // "cacheControlFormat": "anthropic",
        // 是否发送 session affinity headers。
        // "sendSessionAffinityHeaders": true,
        // session affinity header 格式：openai/openai-nosession/openrouter。
        // "sessionAffinityFormat": "openai-nosession",
        // 是否接受长 prompt cache retention。
        // "supportsLongCacheRetention": false,
        // provider 延迟加载工具的序列化模式。
        // "deferredToolsMode": "kimi",
        // z.ai 是否接受顶层 tool_stream=true。
        // "zaiToolStream": true,

        // OpenRouter 的 provider 路由参数。
        // "openRouterRouting": {
        //   "allow_fallbacks": true,
        //   "require_parameters": false,
        //   "data_collection": "deny",
        //   "zdr": true,
        //   "enforce_distillable_text": false,
        //   "order": ["provider-a", "provider-b"],
        //   "only": ["provider-a"],
        //   "ignore": ["provider-c"],
        //   "quantizations": ["fp16", "bf16"],
        //   "sort": { "by": "latency", "partition": "model" },
        //   "max_price": {
        //     "prompt": 1,
        //     "completion": 2,
        //     "image": 0.01,
        //     "audio": 0.01,
        //     "request": 0.001
        //   },
        //   "preferred_min_throughput": { "p50": 20, "p90": 10 },
        //   "preferred_max_latency": { "p50": 1, "p90": 3 }
        // },
        // Vercel AI Gateway 的 provider 过滤和顺序。
        // "vercelGatewayRouting": {
        //   "only": ["anthropic", "openai"],
        //   "order": ["anthropic", "openai"]
        // }
      },
      "models": [
        {
          "id": "gemma4-31b-it",
          "name": "Gemma4 31B it",
          "contextWindow": 131072,
          "maxTokens": 32768,
          "thinkingPreset": "chat-template-enabled",
          "defaultThinkingLevel": "off",
          "input": ["text", "image"],
          "defaults": {
            "temperature": 0.2,
            "topP": 0.95,
            // 显式配置的非 OpenAI sampling 字段会直接发送。
            "topK": 40,
            "maxTokens": 8192
          }
        }
      ]
    },

    "responses-demo": {
      "name": "Responses Demo",
      "baseUrl": "http://127.0.0.1:11451/v1",
      "apiKey": "EMPTY",
      "api": "openai-responses",
      "thinkingPreset": "chat-template-effort",
      // Responses API 只消费以下四个 compat 字段。
      "compat": {
        // 是否接受 developer role；false 时使用 system role。
        "supportsDeveloperRole": false,
        // session affinity header 格式。
        "sessionAffinityFormat": "openai-nosession",
        // 是否接受 prompt_cache_retention=24h。
        "supportsLongCacheRetention": false,
        // 是否支持由客户端执行的 deferred tool search。
        "supportsToolSearch": false
      },

      "models": [
        {
          "id": "reasoning-model",
          "name": "Reasoning Model",
          "reasoning": true,
          "contextWindow": 65536,
          "maxTokens": 16384,
          "defaultThinkingLevel": "xhigh",
          "thinkingLevelMap": {
            "off": "none",
            "minimal": null,
            "xhigh": "max"
          }
        }
      ]
    },

    "chat-template-enabled-demo": {
      "name": "Chat Template Enabled Demo",
      "baseUrl": "http://127.0.0.1:9000/v1",
      "apiKey": "EMPTY",
      "api": "openai-completions",
      "thinkingPreset": "chat-template-enabled",
      "compat": {
        "supportsStore": false,
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false,
        "maxTokensField": "max_tokens"
      },
      "models": [
        {
          "id": "boolean-thinking-model",
          "name": "Boolean Thinking Model",
          "contextWindow": 131072,
          "maxTokens": 32768,
          "defaultThinkingLevel": "high"
        }
      ]
    }
  }
}
